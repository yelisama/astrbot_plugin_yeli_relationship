{
    "enabled":  {
                    "description":  "启用夜璃关系本",
                    "type":  "bool",
                    "hint":  "总开关。关闭后不读取、不写入、不向 bot 注入关系资料。",
                    "default":  true
                },
    "mode":  {
                 "description":  "运行模式",
                 "type":  "string",
                 "hint":  "推荐 auto。可填：off=关闭；read_only=只读取不写入；group_only=仅群聊；manual=只允许人工维护；auto=自动读取并低风险维护。",
                 "default":  "auto"
             },
    "scope_sharing_mode":  {
                               "description":  "资料互通方式",
                               "type":  "string",
                               "hint":  "推荐 global_fallback。可填：isolated=群聊/私聊/全局互不影响；global_fallback=当前作用域优先，全局资料补充；shared=同一 QQ 的资料可跨作用域互通。",
                               "default":  "global_fallback"
                           },
    "private_read_enabled":  {
                                 "description":  "私聊允许读取资料",
                                 "type":  "bool",
                                 "hint":  "开启后，私聊里 bot 可以读取对应私聊资料。不会自动把私聊资料带进群聊，除非资料互通方式允许。",
                                 "default":  true
                             },
    "private_stats_enabled":  {
                                  "description":  "私聊允许自动统计",
                                  "type":  "bool",
                                  "hint":  "默认关闭。开启后，私聊也会自动创建资料和统计活跃。担心私聊影响群聊时保持关闭。",
                                  "default":  false
                              },
    "enable_group_whitelist":  {
                                   "description":  "启用群聊白名单",
                                   "type":  "bool",
                                   "hint":  "开启后，只在 group_whitelist 填写的群里启用关系本。",
                                   "default":  false
                               },
    "group_whitelist":  {
                            "description":  "群聊白名单",
                            "type":  "list",
                            "hint":  "填写群号，例如 123456789。关闭群聊白名单时此项不生效。",
                            "default":  [

                                        ]
                        },
    "enable_user_whitelist":  {
                                  "description":  "启用用户白名单",
                                  "type":  "bool",
                                  "hint":  "开启后，只对白名单 QQ 触发读取或写入。一般不需要开启。",
                                  "default":  false
                              },
    "user_whitelist":  {
                           "description":  "用户白名单",
                           "type":  "list",
                           "hint":  "填写 QQ 号。WebUI 的“切到私聊资料”也会读取这里的用户列表。",
                           "default":  [

                                       ]
                       },
    "inject_budget_mode":  {
                               "description":  "注入强度",
                               "type":  "string",
                               "hint":  "推荐 balanced。可填：compact=省 token；balanced=均衡；rich=信息更完整。控制关系短卡长度，避免影响 bot 回复质量。",
                               "default":  "balanced"
                           },
    "inject_active_profiles_enabled":  {
                                           "description":  "附带高活跃群友",
                                           "type":  "bool",
                                           "hint":  "默认关闭。开启后会在预算内追加当前作用域高活跃资料，可能增加 token 并分散注意力。",
                                           "default":  false
                                       },
    "enable_relationship_self_awareness":  {
                                               "description":  "让 bot 知道关系本存在",
                                               "type":  "bool",
                                               "hint":  "推荐开启。bot 被问到能力时会知道自己有夜璃关系本，但没有资料时不能编造。",
                                               "default":  true
                                           },
    "relationship_auto_maintain_enabled":  {
                                               "description":  "允许 bot 低风险补充资料",
                                               "type":  "bool",
                                               "hint":  "推荐开启。只在后台低频分析聊天，补充称呼、别名、关系标签、简短备注；会避开真实身份、学校、联系方式等敏感信息。",
                                               "default":  true
                                           },
    "llm_provider_id":  {
                            "description":  "关系分析模型",
                            "type":  "string",
                            "hint":  "从 AstrBot 已配置并启用的模型中选择一个，专门用于关系资料分析。插件直接使用所选模型，不跟随当前聊天模型；未选择时不会执行自动关系分析。",
                            "default":  "",
                            "_special":  "select_provider"
                        },
    "llm_retry_times":  {
                            "description":  "关系分析重试次数",
                            "type":  "int",
                            "hint":  "关系分析 LLM 调用失败时的重试次数，建议 1-3。过高会增加延迟和费用。",
                            "default":  2
                        },
    "alias_match_enabled":  {
                                "description":  "启用昵称/别名命中",
                                "type":  "bool",
                                "hint":  "推荐开启。消息提到某个昵称或别名时，按需注入对应资料；多人共用别名会跳过并在诊断里提示冲突。",
                                "default":  true
                            }
}
